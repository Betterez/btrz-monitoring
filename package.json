{
  "name": "btrz-monitoring",
  "version": "1.0.1",
  "description": "Code to help instrument applications for monitoring.",
  "main": "dist/index.js",
  "engines": {
    "node": ">= 22",
    "npm": ">= 5"
  },
  "scripts": {
    "compile": "npx tsc",
    "watch": "npx tsc -w",
    "test": "node --require ts-node/register --test test/**/*.test.ts",
    "tdd": "node --require ts-node/register --test --watch test/**/*.test.ts",
    "delete-compiled-code": "rm -rf dist/",
    "commit-compiled-code": "git add --force dist/ && git commit --allow-empty -m \"Compiled code\"",
    "preversion": "npm test && npm run delete-compiled-code && npm run compile && npm run commit-compiled-code",
    "postversion": "git push origin master && git push --tags"
  },
  "author": "Betterez Inc.",
  "license": "ISC",
  "dependencies": {
    "@aws/aws-distro-opentelemetry-node-autoinstrumentation": "0.12.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/core": "2.8.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.219.0",
    "@opentelemetry/id-generator-aws-xray": "2.1.0",
    "@opentelemetry/propagator-aws-xray": "^2.2.0",
    "@opentelemetry/resource-detector-aws": "^2.20.0",
    "@opentelemetry/sdk-metrics": "2.8.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/semantic-conventions": "1.43.0",
    "ansi-colors": "4.1.3"
  },
  "devDependencies": {
    "ts-node": "10.9.2",
    "typescript": "5.8.3"
  }
}
